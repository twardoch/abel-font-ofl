      },
      {
        "name":"aalt",
        "feature":"feature aalt useExtension {\n# GSUB feature: Access All Alternates\n# Lookups: 1\n\n  sub A by ordfeminine;\n  sub O by ordmasculine;\n  sub a by ordfeminine;\n  sub o by ordmasculine;\n  sub one by onesuperior;\n  sub two by twosuperior;\n  sub three by threesuperior;\n} aalt;\n\n"
      },
      {
        "name":"frac",
        "feature":"feature frac {\n# GSUB feature: Fractions\n# Lookups: 1\n\n  lookup frac;\n\n} frac;\n\n"
      },
      {
        "name":"kern",
        "feature":"feature kern {\n# GPOS feature: Kerning\n# Lookups: 1\n\n  lookup kern;\n\n} kern;\n\n"
      },
      {
        "name":"locl",
        "feature":"feature locl {\n# GSUB feature: Localized Forms\n# Lookups: 1\n\n  script latn; # Latin\n    language CAT ; # Catalan\n    lookup locl_latnCAT_1;\n\n\n} locl;\n\n"
      },
      {
        "name":"ordn",
        "feature":"feature ordn {\n# GSUB feature: Ordinals\n# Lookups: 1\n\n  lookup ordn_1;\n\n} ordn;\n\n"
      },
      {
        "name":"sups",
        "feature":"feature sups {\n# GSUB feature: Superscript\n# Lookups: 1\n\n  lookup sups;\n\n} sups;\n\n"
      }
    ],
